# Tushare Pro API Token (可选，用于获取更详细的财务数据)
TUSHARE_TOKEN=

# LLM 配置（用于智能研报和自然语言选股）
# 支持的 provider: claude / qwen / deepseek / zhipu / openai
LLM_PROVIDER=claude

# Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 通义千问（阿里）— https://dashscope.console.aliyun.com/
# LLM_PROVIDER=qwen
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# DeepSeek — https://platform.deepseek.com/
# LLM_PROVIDER=deepseek
# OPENAI_API_KEY=your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# 智谱 GLM（清华）— https://open.bigmodel.cn/
# LLM_PROVIDER=zhipu
# OPENAI_API_KEY=your-zhipu-key
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_MODEL=glm-4-flash

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# 数据库路径
DUCKDB_PATH=data/duckdb/stock.duckdb

# 日志级别
LOG_LEVEL=INFO
